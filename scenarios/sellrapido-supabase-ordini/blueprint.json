{
  "_note": "v1.6.1 — fix: marketplace_status IML era sbilanciata (8 chiuse invece di 6). Approccio or()+lower() con 6 if() annidati. Parens bilanciate: 28 open = 28 close.",
  "name": "SellRapido → Supabase | Ordini Marketplace",
  "version": "1.6.1",
  "make_scenario_id": 8831616,
  "scheduling": {
    "type": "indefinitely",
    "interval": 900,
    "_note": "Ogni 15 minuti"
  },
  "flow": [
    {
      "id": 1,
      "module": "http:ActionSendData",
      "description": "POST SellRapido — recupero ordini ultimi 30 giorni",
      "method": "POST",
      "url": "https://app.sellrapido.com/sr_company_ws/api/order/[SELLRAPIDO_API_KEY]",
      "bodyType": "raw",
      "contentType": "application/json",
      "body": "{\"startDate\": \"{{formatDate(addDays(now; -30); \\\"YYYY-MM-DD\\\")}}\", \"format\": \"json\"}",
      "_note": "v1.6: rimosso filtro status — si recuperano TUTTI gli ordini"
    },
    {
      "id": 2,
      "module": "builtin:BasicFeeder",
      "description": "Iterator su array orders",
      "array": "{{1.data.orders}}"
    },
    {
      "id": 3,
      "module": "http:ActionSendData",
      "description": "GET Supabase marketplaces — lookup per sellrapido_code (colonna dedicata)",
      "method": "GET",
      "url": "https://smozehzbhoeceioqxodx.supabase.co/rest/v1/marketplaces",
      "querystring": {
        "sellrapido_code": "eq.{{lower(2.head.channel_code)}}",
        "select": "id"
      },
      "headers": {
        "apikey": "[SUPABASE_ANON_KEY]",
        "Authorization": "Bearer [SUPABASE_ANON_KEY]"
      },
      "_note": "lower() per match case-insensitive del channel_code"
    },
    {
      "id": 4,
      "module": "http:ActionSendData",
      "description": "POST upsert ordine in orders (solo se marketplace trovato)",
      "filter": "Marketplace trovato: {{length(3.data)}} > 0",
      "method": "POST",
      "url": "https://smozehzbhoeceioqxodx.supabase.co/rest/v1/orders",
      "querystring": {
        "on_conflict": "marketplace_id,marketplace_order_id",
        "columns": "marketplace_id,marketplace_order_id,order_date,customer_name,customer_email,shipping_address,order_value,shipping_value,marketplace_fee,marketplace_status"
      },
      "headers": {
        "apikey": "[SUPABASE_ANON_KEY]",
        "Authorization": "Bearer [SUPABASE_ANON_KEY]",
        "Prefer": "resolution=merge-duplicates,return=representation",
        "Accept": "application/vnd.pgrst.object+json"
      },
      "marketplace_status_iml": "{{if(lower(2.head.status) = \"standby\"; \"pending\"; if(or(lower(2.head.status) = \"accepted\"; lower(2.head.status) = \"accettato\"); \"confirmed\"; if(or(lower(2.head.status) = \"sent\"; lower(2.head.status) = \"spedito\"); \"shipped\"; if(or(lower(2.head.status) = \"delivered\"; lower(2.head.status) = \"consegnato\"); \"delivered\"; if(or(lower(2.head.status) = \"cancelled\"; lower(2.head.status) = \"annullato\"); \"cancelled\"; if(or(lower(2.head.status) = \"refunded\"; lower(2.head.status) = \"rimborsato\"); \"refunded\"; \"pending\"))))))}}}",
      "_note_iml": "v1.6.1: FIX — era sbilanciata (30 close vs 28 open). or() per EN+IT status pairs con lower(). 6 if() annidati. 28 open = 28 close.",
      "_mapping": {
        "standby": "pending",
        "accepted/accettato": "confirmed",
        "sent/spedito": "shipped",
        "delivered/consegnato": "delivered",
        "cancelled/annullato": "cancelled",
        "refunded/rimborsato": "refunded",
        "default": "pending"
      }
    },
    {
      "id": 7,
      "module": "util:SetVariable2",
      "description": "Salva orderId per uso in modulo 6",
      "name": "orderId",
      "scope": "roundtrip",
      "value": "{{4.data.id}}"
    },
    {
      "id": 5,
      "module": "builtin:BasicFeeder",
      "description": "Iterator su rows (righe prodotto dell'ordine)",
      "array": "{{2.rows}}"
    },
    {
      "id": 6,
      "module": "http:ActionSendData",
      "description": "POST Supabase upsert riga prodotto in order_items",
      "method": "POST",
      "url": "https://smozehzbhoeceioqxodx.supabase.co/rest/v1/order_items",
      "querystring": {
        "on_conflict": "order_id,product_sku"
      },
      "headers": {
        "apikey": "[SUPABASE_ANON_KEY]",
        "Authorization": "Bearer [SUPABASE_ANON_KEY]",
        "Prefer": "resolution=merge-duplicates,return=representation"
      },
      "body": {
        "order_id": "{{7.orderId}}",
        "product_sku": "{{5.sku}}",
        "product_name": "{{5.title}}",
        "product_ean": "{{5.ean}}",
        "quantity": "{{ifempty(5.quantity; 1)}}",
        "sale_price": "{{ifempty(5.price; 0)}}",
        "supplier_cost": "{{ifempty(5.price_cost; 0)}}",
        "tracking_number": "{{5.tracking}}"
      }
    }
  ]
}