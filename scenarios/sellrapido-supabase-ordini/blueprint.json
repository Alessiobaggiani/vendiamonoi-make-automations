{
  "_note": "Le API key Supabase (apikey/Authorization) sono state sostituite con [SUPABASE_ANON_KEY]. Recuperare la chiave reale dal pannello Supabase > Settings > API. La API key SellRapido è sostituita con [SELLRAPIDO_API_KEY].",
  "name": "SellRapido → Supabase | Ordini Marketplace",
  "make_scenario_id": 8831616,
  "scheduling": {
    "type": "indefinitely",
    "interval": 900,
    "_note": "Ogni 15 minuti"
  },
  "flow": [
    {
      "id": 1,
      "module": "http:ActionSendData",
      "description": "POST SellRapido — recupero ordini ultimi 30 giorni con status validi",
      "method": "POST",
      "url": "https://app.sellrapido.com/sr_company_ws/api/order/[SELLRAPIDO_API_KEY]",
      "bodyType": "raw",
      "contentType": "application/json",
      "body": "{\"startDate\": \"{{formatDate(addDays(now; -30); \\\"YYYY-MM-DD\\\")}}\", \"format\": \"json\", \"status\": [\"standby\", \"accepted\", \"sent\", \"cancelled\"]}",
      "_note": "v1.3: status corretti per SellRapido API — i valori reali sono standby/accepted/sent/cancelled. 'shipped'/'delivered' NON esistono nell'API SellRapido."
    },
    {
      "id": 2,
      "module": "builtin:BasicFeeder",
      "description": "Iterator su array orders",
      "array": "{{1.data.orders}}"
    },
    {
      "id": 3,
      "module": "http:ActionSendData",
      "description": "GET Supabase marketplaces — lookup per sellrapido_code (colonna dedicata)",
      "method": "GET",
      "url": "https://smozehzbhoeceioqxodx.supabase.co/rest/v1/marketplaces",
      "querystring": {
        "sellrapido_code": "eq.{{2.head.channel_code}}",
        "select": "id"
      },
      "headers": {
        "apikey": "[SUPABASE_ANON_KEY]",
        "Authorization": "Bearer [SUPABASE_ANON_KEY]"
      },
      "_note": "v1.3: lookup ora usa colonna sellrapido_code (dedicata) invece di slug. PREREQUISITO: popolare marketplaces.sellrapido_code con i codici canale SellRapido."
    },
    {
      "id": 4,
      "module": "http:ActionSendData",
      "description": "POST upsert ordine in orders (solo se marketplace trovato)",
      "filter": "Marketplace trovato: {{length(3.data)}} > 0",
      "method": "POST",
      "url": "https://smozehzbhoeceioqxodx.supabase.co/rest/v1/orders",
      "querystring": {
        "on_conflict": "marketplace_id,marketplace_order_id",
        "columns": "marketplace_id,marketplace_order_id,order_date,customer_name,customer_email,shipping_address,order_value,shipping_value,marketplace_fee,marketplace_status"
      },
      "headers": {
        "apikey": "[SUPABASE_ANON_KEY]",
        "Authorization": "Bearer [SUPABASE_ANON_KEY]",
        "Prefer": "resolution=merge-duplicates,return=representation",
        "Accept": "application/vnd.pgrst.object+json"
      },
      "body_raw_template": "{\"marketplace_id\": \"{{first(3.data).id}}\", \"marketplace_order_id\": \"{{2.head.code}}\", \"order_date\": \"{{ifempty(2.head.date_order; ifempty(2.head.create_date; now))}}\", \"customer_name\": \"{{2.head.buyer_name}}\", \"customer_email\": \"{{2.head.buyer_email}}\", \"shipping_address\": {{\"{\\\"street\\\":\\\"\" & 2.head.buyer_address1 & \"\\\",\\\"city\\\":\\\"\" & 2.head.buyer_city & \"\\\",\\\"zip\\\":\\\"\" & 2.head.buyer_zip & \"\\\",\\\"country\\\":\\\"\" & 2.head.buyer_country & \"\\\"}\"}}, \"order_value\": {{ifempty(2.head.price; 0)}}, \"shipping_value\": {{ifempty(2.head.shipping_price; 0)}}, \"marketplace_fee\": {{ifempty(2.head.marketplace_fee; 0)}}, \"marketplace_status\": \"{{if(2.head.status = \\\"standby\\\"; \\\"pending\\\"; if(2.head.status = \\\"accepted\\\"; \\\"confirmed\\\"; if(2.head.status = \\\"sent\\\"; \\\"shipped\\\"; if(2.head.status = \\\"cancelled\\\"; \\\"cancelled\\\"; \\\"pending\\\"))))}}\"}",
      "_shipping_address_note": "v1.4: parseJSON() NON esiste in Make IML. Fix: string concat dentro {{...}} — la '{' che apre il JSON object è dentro l'espressione IML come string literal, non esposta al legacy parser. Output: {\"street\":\"val\",\"city\":\"val\",\"zip\":\"val\",\"country\":\"val\"}",
      "body_readable": {
        "marketplace_id": "{{first(3.data).id}}",
        "marketplace_order_id": "{{2.head.code}}",
        "order_date": "{{ifempty(2.head.date_order; ifempty(2.head.create_date; now))}}",
        "customer_name": "{{2.head.buyer_name}}",
        "customer_email": "{{2.head.buyer_email}}",
        "shipping_address": "{{parseJSON(...)}} — JSONB object via IML, NON oggetto JSON nudo (fix NaN)",
        "order_value": "{{ifempty(2.head.price; 0)}}",
        "shipping_value": "{{ifempty(2.head.shipping_price; 0)}}",
        "marketplace_fee": "{{ifempty(2.head.marketplace_fee; 0)}}",
        "marketplace_status": "standby→pending | accepted→confirmed | sent→shipped | cancelled→cancelled | default→pending"
      },
      "_mapping_note": {
        "shipping_address": "v1.3: usa {{parseJSON(...)}} per evitare Make NaN warning (il parser legacy interpreta '{' nudo come riferimento a modulo)",
        "marketplace_status": "v1.3: mapping corretto — sent→shipped (era mancante), cancelled→cancelled. Rimossi shipped/delivered che non esistono in SellRapido.",
        "internal_status": "non incluso — usa default DB 'new'; protetto da 'columns' su update",
        "order_date": "fallback chain: date_order → create_date → now()"
      }
    },
    {
      "id": 7,
      "module": "util:SetVariable2",
      "description": "Salva orderId per uso in modulo 6",
      "name": "orderId",
      "scope": "roundtrip",
      "value": "{{4.data.id}}"
    },
    {
      "id": 5,
      "module": "builtin:BasicFeeder",
      "description": "Iterator su rows (righe prodotto dell'ordine)",
      "array": "{{2.rows}}"
    },
    {
      "id": 6,
      "module": "http:ActionSendData",
      "description": "POST Supabase upsert riga prodotto in order_items",
      "method": "POST",
      "url": "https://smozehzbhoeceioqxodx.supabase.co/rest/v1/order_items",
      "querystring": {
        "on_conflict": "order_id,product_sku"
      },
      "headers": {
        "apikey": "[SUPABASE_ANON_KEY]",
        "Authorization": "Bearer [SUPABASE_ANON_KEY]",
        "Prefer": "resolution=merge-duplicates,return=representation"
      },
      "body": {
        "order_id": "{{7.orderId}}",
        "product_sku": "{{5.sku}}",
        "product_name": "{{5.title}}",
        "product_ean": "{{5.ean}}",
        "quantity": "{{ifempty(5.quantity; 1)}}",
        "sale_price": "{{ifempty(5.price; 0)}}",
        "supplier_cost": "{{ifempty(5.price_cost; 0)}}",
        "tracking_number": "{{5.tracking}}"
      }
    }
  ]
}
